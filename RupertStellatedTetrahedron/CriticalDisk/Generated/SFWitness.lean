theorem certifiedRows_stressValid :
    ∀ i : Fin certifiedRows.length,
      (certifiedRows.get i).witness.Valid psiMin tiltCap := by
  intro i
  exact SFStressWitness.valid_of_validBool_eq_true
    (certifiedRows_stressValidBool i)

theorem certifiedRows_stressValid_mem :
    ∀ row ∈ certifiedRows, row.witness.Valid psiMin tiltCap := by
  rw [List.forall_mem_iff_get]
  intro i
